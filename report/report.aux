\@writefile{toc}{\contentsline {section}{\numberline {3}系統架構}{2}{section.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces 系統五層架構（Swim-lane 視覺化）：Client 6 個頁面 → API Routes 10 endpoints → 演算法層 → 內部資料（GeoJSON / Mock / LocalStorage）→ 外部資料源（OSM / 北水處 / CWA）。實線=內部呼叫，虛線=外部 API。\texttt  {/me} 直連 LocalStorage 不經 server 以保護隱私。}}{2}{figure.caption.1}\protected@file@percent }
