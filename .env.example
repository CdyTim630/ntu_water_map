# Supabase 設定（之後接 Supabase 時填入；現在使用 mock 資料可留空）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Storage bucket name（圖片上傳）
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=report-images

# 是否使用 mock 資料（true / false）。沒有設定 Supabase 時建議設為 true
NEXT_PUBLIC_USE_MOCK=true

# Admin 後台密碼（簡易登入用）
ADMIN_PASSWORD=ntu-water-admin-2026

# 中央氣象署 OpenData API 金鑰（雨天路徑規劃用）
# 申請：https://opendata.cwa.gov.tw/userLogin
# 沒填的話會自動使用 mock 氣象資料，仍可體驗雨天路徑功能
CWA_API_KEY=
